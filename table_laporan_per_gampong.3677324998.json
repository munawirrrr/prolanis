{
	"orderInfo": [
		{
			"index": 3,
			"asc": true,
			"field": "CONCAT(CASE MONTH(`tanggal`)\n        WHEN 1  THEN '01'\n        WHEN 2  THEN '02'\n        WHEN 3  THEN '03'\n        WHEN 4  THEN '04'\n        WHEN 5  THEN '05'\n        WHEN 6  THEN '06'\n        WHEN 7  THEN '07'\n        WHEN 8  THEN '08'\n        WHEN 9  THEN '09'\n        WHEN 10 THEN '10'\n        WHEN 11 THEN '11'\n        WHEN 12 THEN '2'\n    END)"
		}
	],
	"sql": "SELECT\ngampong.gampong,\ndaftar.tahun,\nCONCAT(CASE MONTH(`tanggal`)\n        WHEN 1  THEN '01'\n        WHEN 2  THEN '02'\n        WHEN 3  THEN '03'\n        WHEN 4  THEN '04'\n        WHEN 5  THEN '05'\n        WHEN 6  THEN '06'\n        WHEN 7  THEN '07'\n        WHEN 8  THEN '08'\n        WHEN 9  THEN '09'\n        WHEN 10 THEN '10'\n        WHEN 11 THEN '11'\n        WHEN 12 THEN '2'\n    END) AS bulan,\ndaftar.tanggal,\npasien.nama,\ndaftar.nik,\npasien.tanggal_lahir,\nConcat(FLOOR(DATEDIFF(DATE_FORMAT(NOW(), '%Y-07-01'), pasien.`tanggal_lahir`) / 365.25), \" Tahun \") AS usia,\ndaftar.diagnosa,\ndaftar.keterangan\nFROM daftar\nINNER JOIN pasien ON daftar.nik = pasien.nik\nINNER JOIN gampong ON pasien.id_gampong = gampong.id\nWHERE (daftar.status = 'disetujui')\nORDER BY CONCAT(CASE MONTH(`tanggal`)\n        WHEN 1  THEN '01'\n        WHEN 2  THEN '02'\n        WHEN 3  THEN '03'\n        WHEN 4  THEN '04'\n        WHEN 5  THEN '05'\n        WHEN 6  THEN '06'\n        WHEN 7  THEN '07'\n        WHEN 8  THEN '08'\n        WHEN 9  THEN '09'\n        WHEN 10 THEN '10'\n        WHEN 11 THEN '11'\n        WHEN 12 THEN '2'\n    END)",
