{
	"sql": "SELECT\r\n    import.id,\r\n    import.bpjs,\r\n    pasien.nik,\r\n    pasien.nama,\r\n    pasien.Tanggal_lahir,\r\n    pasien.hp_pasien,\r\n    pasien.Jenis_kelamin,\r\n    gampong.gampong,\r\n    CASE\r\n        WHEN (\r\n            SELECT COUNT(*) FROM pasien p2\r\n            WHERE p2.nik = pasien.nik\r\n              AND p2.nama <> pasien.nama\r\n              AND p2.nik IS NOT NULL AND p2.nik <> ''\r\n        ) > 0\r\n        THEN (\r\n            SELECT CONCAT('Duplicate NIK dengan : ', GROUP_CONCAT(DISTINCT p2.nama SEPARATOR ', '))\r\n            FROM pasien p2\r\n            WHERE p2.nik = pasien.nik\r\n              AND p2.nama <> pasien.nama\r\n        )\r\n        WHEN (\r\n            SELECT COUNT(*) FROM pasien p3\r\n            WHERE p3.bpjs = pasien.bpjs\r\n              AND p3.nama <> pasien.nama\r\n              AND p3.bpjs IS NOT NULL AND p3.bpjs <> ''\r\n        ) > 0\r\n        THEN (\r\n            SELECT CONCAT('Duplicate BPJS dengan : ', GROUP_CONCAT(DISTINCT p3.nama SEPARATOR ', '))\r\n            FROM pasien p3\r\n            WHERE p3.bpjs = pasien.bpjs\r\n              AND p3.nama <> pasien.nama\r\n        )\r\n        ELSE ''\r\n    END AS keterangan\r\nFROM import\r\nLEFT OUTER JOIN pasien ON (\r\n    (import.bpjs IS NOT NULL AND import.bpjs <> '' AND pasien.bpjs = import.bpjs)\r\n    OR\r\n    (import.nik IS NOT NULL AND import.nik <> '' AND pasien.nik = import.nik)\r\n)\r\nLEFT OUTER JOIN gampong ON pasien.id_gampong = gampong.id\r\n",
	"connId": "penmadpiprolanisatpenmadpidiec",
