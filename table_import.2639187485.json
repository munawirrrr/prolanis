{
	"sql": "SELECT\r\n    import.id,\r\n    import.tanggal,\r\n    import.bpjs,\r\n    pasien.nik,\r\n    pasien.nama,\r\n    pasien.Tanggal_lahir,\r\n    pasien.hp_pasien,\r\n    pasien.Jenis_kelamin,\r\n    gampong.gampong,\r\n    CONCAT(\r\n    '<a href=\"pasien_add.php?masterkey1=',import.bpjs, '&mastertable=import\" ',\r\n    'onclick=\"window.open(this.href,\\'popupRekam\\',',\r\n    '\\'width=900,height=600,scrollbars=yes,resizable=yes\\');return false;\" ',\r\n    'style=\"display:inline-flex;align-items:center;gap:6px;padding:6px 16px;',\r\n    'background:#1a6fc4;color:#ffffff;border-radius:6px;font-size:12px;',\r\n    'font-weight:500;text-decoration:none;font-family:sans-serif;',\r\n    'border:none;cursor:pointer;\" ',\r\n    'onmouseover=\"this.style.background=\\'#155aa0\\'\" ',\r\n    'onmouseout=\"this.style.background=\\'#1a6fc4\\'\">',\r\n    '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" ',\r\n    'stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" ',\r\n    'style=\"vertical-align:middle;margin-right:4px;\">',\r\n    '<path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/>',\r\n    '<circle cx=\"9\" cy=\"7\" r=\"4\"/>',\r\n    '<line x1=\"19\" y1=\"8\" x2=\"19\" y2=\"14\"/>',\r\n    '<line x1=\"22\" y1=\"11\" x2=\"16\" y2=\"11\"/>',\r\n    '</svg>',\r\n    'lengkapi data</a>'\r\n  ) AS rekam_pasien\r\n    \r\nFROM import\r\nLEFT OUTER JOIN pasien ON (\r\n    (import.bpjs IS NOT NULL AND import.bpjs <> '' AND pasien.bpjs = import.bpjs)\r\n    OR\r\n    (import.nik IS NOT NULL AND import.nik <> '' AND pasien.nik = import.nik)\r\n)\r\nLEFT OUTER JOIN gampong ON pasien.id_gampong = gampong.id\r\n",
	"connId": "penmadpiprolanisatpenmadpidiec",
