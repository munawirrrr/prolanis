{
	"sql": "SELECT\n    pasien.nik,\n    CASE \n        WHEN EXISTS (\n            SELECT 1 \n            FROM daftar \n            WHERE daftar.nik = pasien.nik\n        ) \n        THEN 'pasien_prolanis'\n        ELSE \"\"\n        END AS catatan,\n    pasien.nama,\n    DATE_FORMAT(pasien.tanggal_lahir, '%Y-%m-%d') AS Tanggal_lahir,\n    pasien.bpjs,\n    pasien.id_gampong,\n    pasien.jenis_kelamin,\n    pasien.hp_pasien\nFROM pasien;",
