	"eventHandlers": [
		{
			"eventId": "EVENT_BEFOREADD",
			"pageType": "add",
			"code": "// Ambil nama gampong dari tabel gampong\n$rs = DB::Query(\"\n    SELECT gampong \n    FROM gampong \n    WHERE id = \".$values[\"id_gampong\"]\n);\n$data = $rs->fetchAssoc();\n\n$nama_gampong = \"\";\nif ($data) {\n    $nama_gampong = preg_replace('/[^a-zA-Z0-9_]/', '_', strtolower($data[\"gampong\"]));\n}\n\n// Decode file json\n$fileArray = my_json_decode($values[\"file_excel\"]);\n\nfor ($i = 0; $i < count($fileArray); $i++) {\n\n    $fileName = $fileArray[$i][\"name\"];\n\n    $newFileName = \"files/data_\"\n        .$nama_gampong\n        .\"_kode_id_\"\n        .$values[\"id_gampong\"]\n        .\".xlsx\";\n\n    rename($fileName, getabspath($newFileName));\n\n    $fileArray[$i][\"name\"] = $newFileName;\n}\n\n// Encode ulang ke json\n$values[\"file_excel\"] = my_json_encode($fileArray);\n\nreturn true;"
		},
		{
			"eventId": "EVENT_BEFOREMOVENEXT_LIST",
			"pageType": "list",
			"code": "// cek user login\n   if (Security::isGuest()){\n        \n        // kosongkan nilai kolom\n        $pageObject->hideField(\"file_excel\"); \n         $pageObject->hideField(\"nomor_hp\");\n    }\n\n\n// Place event code here.\n// Use \"Add Action\" button to add code snippets."
		},
		{
			"eventId": "EVENT_BEFORESHOW_LIST",
			"pageType": "list",
			"code": "if (Security::isGuest()){\n\n$pageObject->hideItem(\"status\");\n\n\n}\n// Place event code here.\n// Use \"Add Action\" button to add code snippets."
		}
	],
